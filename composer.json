{
	"name": "mildabre/kamenictvi",
	"description": "Commercial website Tomáš Čierny",
	"type": "project",
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/mildabre/bite.git"
		}
	],
	"require": {
		"php": "^8.4",
		"ext-mbstring": "*",
		"ext-intl": "*",
		"ext-pdo": "*",
		"mildabre/bite": "^0.1",
		"cweagans/composer-patches": "^1.7"
	},
	"require-dev": {
		"nette/tester": "^2.5"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"extra": {
		"patches": {
			"nette/application": {
				"LinkGenerator state parameters, Presenter lifecycle hooks": "vendor/mildabre/bite/patches/nette-application.patch"
			}
		}
	},
	"config": {
		"allow-plugins": {
			"cweagans/composer-patches": true
		}
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
